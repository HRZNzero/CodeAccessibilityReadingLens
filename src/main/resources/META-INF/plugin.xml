<idea-plugin>
    <id>com.example.codestructurevisualizer</id>
    <name>Code Structure Visualizer</name>
    <vendor email="support@example.com">Example</vendor>
    <description><![CDATA[
        Adds subtle colour-coded background groups to Java files.
        Optional nested bracket-level colouring, focus/dim mode, camelCase word-spacing,
        indented-box layout, wider field spacing, syntax token emphasis, and
        a control-flow view that highlights all if/else/switch blocks.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <idea-version since-build="253"/>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.example.codestructurevisualizer.JavaStructureStartupActivity"/>
        <notificationGroup id="Code Structure Visualizer" displayType="BALLOON"/>
        <projectService serviceImplementation="com.example.codestructurevisualizer.CamelCaseSpacingService"/>
        <projectService serviceImplementation="com.example.codestructurevisualizer.SyntaxEmphasisSettings"/>
        <projectService serviceImplementation="com.example.codestructurevisualizer.SyntaxEmphasisService"/>
        <projectService serviceImplementation="com.example.codestructurevisualizer.MarkerService"/>
        <projectService serviceImplementation="com.example.codestructurevisualizer.JavaStructureHighlighterService"/>
    </extensions>

    <actions>
        <!-- ── core overlay ──────────────────────────────────────────────── -->
        <action id="CodeStructureVisualizer.ToggleOverlay"
                class="com.example.codestructurevisualizer.ToggleJavaStructureOverlayAction"
                text="Toggle Code Structure Overlay"
                description="Turn the Java structure visualization overlay on or off">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift B"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="CodeStructureVisualizer.ToggleNestedSubsections"
                class="com.example.codestructurevisualizer.ToggleNestedSubsectionsOverlayAction"
                text="Toggle Nested Code Block Colours"
                description="Turn nested bracket-level colouring inside methods on or off">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift G"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── focus / dim  (was D – conflicted; now F for Focus) ────────── -->
        <action id="CodeStructureVisualizer.ToggleInspectionMode"
                class="com.example.codestructurevisualizer.ToggleInspectionModeAction"
                text="Toggle Focus Mode (Dim)"
                description="Dim all code except the bracket / method the cursor is currently in">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift F"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── camelCase word-spacing ─────────────────────────────────────── -->
        <action id="CodeStructureVisualizer.ToggleCamelCaseSpacing"
                class="com.example.codestructurevisualizer.ToggleCamelCaseSpacingAction"
                text="Toggle Identifier Word-Spacing"
                description="Add tiny visual gaps + bold at camelCase/snake_case word boundaries">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift W"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── syntax emphasis config  (was E – conflicted; now Y) ────────── -->
        <action id="CodeStructureVisualizer.SyntaxEmphasisConfig"
                class="com.example.codestructurevisualizer.ToggleSyntaxEmphasisAction"
                text="Configure Syntax Emphasis (Bold / Colour)…"
                description="Toggle bold and custom colour for if / ( ) / ? / ; / &quot; / . / { } / [ ] / &lt;&gt;">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift Y"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── indented boxes ─────────────────────────────────────────────── -->
        <action id="CodeStructureVisualizer.ToggleIndentedBoxes"
                class="com.example.codestructurevisualizer.ToggleIndentedBoxesAction"
                text="Toggle Indented Boxes"
                description="Start each colour band at its block's indentation column (nested-box look)">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift X"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── wider field spacing ───────────────────────────────────────── -->
        <action id="CodeStructureVisualizer.ToggleWiderFieldSpacing"
                class="com.example.codestructurevisualizer.ToggleWiderFieldSpacingAction"
                text="Toggle Wider Field Spacing"
                description="Add a thin separator gap between consecutive field background rows">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift K"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── control-flow view ─────────────────────────────────────────── -->
        <action id="CodeStructureVisualizer.ToggleControlFlowMode"
                class="com.example.codestructurevisualizer.ToggleControlFlowModeAction"
                text="Toggle Control-Flow View"
                description="Highlight all if/else/switch blocks in orange; hides level colouring">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift Q"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── marker system ─────────────────────────────────────────────── -->
        <!-- Strip Ctrl+Alt+M from the built-in Extract Method action so our
             marker toggle can claim it.  Extract Method is still reachable via
             the Refactor menu or Find Action (Ctrl+Shift+A). -->
        <action id="ExtractMethod" overrides="true"
                class="com.intellij.refactoring.actions.ExtractMethodAction"
                text="Extract Method...">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M" remove="true"/>
        </action>

        <action id="CodeStructureVisualizer.PlaceMarker"
                class="com.example.codestructurevisualizer.PlaceMarkerAction"
                text="Toggle Line Marker"
                description="Place or remove a marker on the current line (orange gutter stripe)">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="CodeStructureVisualizer.JumpToNextMarker"
                class="com.example.codestructurevisualizer.JumpToNextMarkerAction"
                text="Jump to Next Marker"
                description="Move caret to the next marker in the file, wrapping around">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt DOWN"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="CodeStructureVisualizer.JumpToPrevMarker"
                class="com.example.codestructurevisualizer.JumpToPrevMarkerAction"
                text="Jump to Previous Marker"
                description="Move caret to the previous marker in the file, wrapping around">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt UP"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="CodeStructureVisualizer.ToggleMarkerFocus"
                class="com.example.codestructurevisualizer.ToggleMarkerFocusAction"
                text="Toggle Marker Focus Mode"
                description="Dim and fold all non-marked lines so only marked sections are visible">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift Z"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
